<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>

    <!-- ==================== -->
    <!-- Названия для metainf -->
    <!-- ==================== -->
    
    <entry key="service.name">SBG Pay (QR-оплата)</entry>
    <entry key="payment.name">Оплата через SBG Pay</entry>

    <!-- Настройки внешней системы -->
    <entry key="option.baseUrl">URL сервера POS API</entry>
    <entry key="option.deviceToken">Токен устройства (Device-Token)</entry>
    <entry key="option.lang">Язык (ru/uz/en)</entry>
    <entry key="option.currency">Валюта (UZS)</entry>
    <entry key="option.ttlSeconds">Время жизни платежа (сек.)</entry>
    <entry key="option.pollDelayMs">Интервал опроса статуса (мс)</entry>
    <entry key="option.pollTimeoutSeconds">Таймаут ожидания оплаты (сек.)</entry>
    <entry key="option.loyaltyDisplaySeconds">Длительность показа loyalty QR (сек.)</entry>
    <entry key="option.sendReceipt">Отправлять детали чека в API</entry>

    <!-- Сохраняемые поля платежа -->
    <entry key="field.paymentId">ID платежа</entry>
    <entry key="field.paymentCode">Код платежа</entry>
    <entry key="field.methodId">Метод оплаты</entry>
    <entry key="field.methodName">Название метода</entry>
    <entry key="field.status">Статус</entry>
    <entry key="field.sourcePaymentId">ID исходного платежа</entry>
    <entry key="field.refundId">ID возврата</entry>
    <entry key="field.refundCode">Код возврата</entry>
    <entry key="field.refundStatus">Статус возврата</entry>
    <entry key="field.processing.terminalId">ID терминала</entry>
    <entry key="field.processing.merchantId">ID мерчанта</entry>
    <entry key="field.processing.rrn">RRN</entry>
    <entry key="field.processing.stan">STAN</entry>
    <entry key="field.processing.maskedPan">Маскированный PAN</entry>
    <entry key="field.processing.localTransactionTime">Локальное время транзакции</entry>
    <entry key="field.processing.merchantName">Название мерчанта</entry>
    <entry key="field.processing.merchantAddress">Адрес мерчанта</entry>
    <entry key="field.processing.transactionNumber">Номер транзакции</entry>
    <entry key="field.processing.partnerName">Название партнера</entry>
    <entry key="field.processing.partnerPaymentId">ID платежа партнера</entry>
    <entry key="field.processing.userPhoneNumber">Телефон пользователя</entry>

    <!-- ==================== -->
    <!-- Строки для плагина   -->
    <!-- ==================== -->

    <!-- Загрузка методов -->
    <entry key="loading.methods">Загрузка способов оплаты...</entry>
    <entry key="error.no.methods">Нет доступных способов оплаты</entry>
    <entry key="error.load.methods">Ошибка загрузки способов оплаты: </entry>

    <!-- Выбор метода -->
    <entry key="select.method">SBG Pay: выберите способ оплаты</entry>
    <entry key="error.method.not.found">Способ оплаты не найден</entry>
    <entry key="error.amount.too.small">Сумма меньше минимальной: </entry>
    <entry key="error.amount.too.large">Сумма больше максимальной: </entry>
	<entry key="enter.sum.to.pay">Введите сумму к оплате</entry>

    <!-- Создание платежа -->
    <entry key="creating.payment">Создание платежа...</entry>
    <entry key="preparing">Подготовка...</entry>
    <entry key="error.create.payment">Ошибка создания платежа: </entry>

    <!-- Ожидание оплаты -->
    <entry key="waiting.payment">Ожидание оплаты...</entry>
    <entry key="payment.code">Код: </entry>
    <entry key="scan.qr">Сканируйте QR для оплаты</entry>
    <entry key="amount">К оплате: </entry>

    <!-- Результаты -->
    <entry key="payment.success">Оплата успешна!</entry>
    <entry key="error.timeout">Время ожидания оплаты истекло</entry>
    <entry key="error.payment.failed">Оплата не выполнена: </entry>
    <entry key="loyalty.title">Бонус от SBG Pay</entry>
    <entry key="loyalty.default.text">Ваш купон доступен по QR-коду.</entry>

    <!-- Возврат -->
    <entry key="refund.creating">Создание возврата...</entry>
    <entry key="refund.success">Возврат выполнен</entry>
    <entry key="refund.failed">Возврат не выполнен: </entry>
    <entry key="refund.create.error">Ошибка создания возврата: </entry>
    <entry key="refund.source.missing">Не найден исходный paymentId для возврата</entry>
    <entry key="refund.amount.invalid">Некорректная сумма возврата</entry>
    <entry key="refund.partial.not.supported">Частичный возврат не поддерживается: SBG reversal принимает только полную сумму исходной оплаты</entry>

    <!-- Ошибки HTTP -->
    <entry key="error.unauthorized">Ошибка авторизации: проверьте Device-Token</entry>
    <entry key="error.rate.limit">Слишком много запросов, попробуйте позже</entry>

    <entry key="error.communication">Нет связи с процессингом. Проверьте сеть и повторите операцию.</entry>
    <entry key="error.processing.timeout">Превышено время ожидания ответа от процессинга. Повторите операцию.</entry>
    <entry key="error.unknown">Неизвестная ошибка</entry>
</properties>
